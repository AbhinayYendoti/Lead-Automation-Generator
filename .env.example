# ═══════════════════════════════════════════════════════════════════════
# LeadFlow – Environment Variables Template
# Copy this file to `.env` and fill in your actual values.
# NEVER commit the `.env` file. Only `.env.example` belongs in Git.
# ═══════════════════════════════════════════════════════════════════════

# ─── Server ─────────────────────────────────────────────────────────────
# Port the Express server will listen on
PORT=3000

# ─── MongoDB Atlas ───────────────────────────────────────────────────────
# Full connection URI from your MongoDB Atlas cluster dashboard
# Format: mongodb+srv://<username>:<password>@<cluster-host>/<db-name>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/lead_automation_db

# ─── UltraMsg WhatsApp API ───────────────────────────────────────────────
# Dashboard: https://ultramsg.com/
# Find your Instance ID and Token under your UltraMsg instance settings
ULTRAMSG_INSTANCE_ID=instanceXXXXXX
ULTRAMSG_TOKEN=xxxxxxxxxxxxxxxxxxxx

# WhatsApp number that receives lead alert notifications (with country code)
# Example: +919876543210
WHATSAPP_TO=+91XXXXXXXXXX

# ─── Gmail SMTP (Nodemailer) ─────────────────────────────────────────────
# Use a Gmail App Password (NOT your account password).
# Generate one at: https://myaccount.google.com/apppasswords
# Requires 2-Step Verification to be enabled on the account.
EMAIL_USER=your_gmail_address@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx

# ─── Notification Recipient ──────────────────────────────────────────────
# Email address that receives incoming lead alert notifications
NOTIFY_EMAIL=recipient@example.com

# ─── CORS ────────────────────────────────────────────────────────────────
# Allowed frontend origin. Use your production domain in production.
# Example (production): https://your-app.vercel.app
# Example (local):      http://localhost:3000
ALLOWED_ORIGIN=http://localhost:3000

# ─── Node Environment ────────────────────────────────────────────────────
# Set to "production" in your hosting provider's environment config
NODE_ENV=development
